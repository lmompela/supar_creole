# Config for encoder=bert (fine-tuning BERT as full sequence encoder)
# The BERT model IS the encoder; --embed is ignored at training time.
# Lower LR (5e-5) is standard for fine-tuning pre-trained transformers.

[parser]
encoder = 'bert'
feat = 'bert'
punct = True
buckets = 32
max_len = 150

[training]
optimizer = 'adam'
lr = 5e-5
lr_rate = 1
clip = 5.0
epochs = 70
batch_size = 64
decay = 0.75
decay_steps = 5000
