# Config for encoder=lstm (BiLSTM encoder with tag / char / bert features)
# Higher LR (1e-3) is standard for training LSTM-based parsers from scratch.
# Epochs removed — patience=100 determines stopping (true convergence).
# Note: original Phase 3 runs used epochs=30, which cut off training mid-improvement
# (best checkpoints were saved at epoch 30, the very last epoch). Phase 3b reruns
# use patience-based stopping to find the true optimum.

[parser]
encoder = 'lstm'
punct = True
buckets = 32
max_len = 150

[training]
optimizer = 'adam'
lr = 1e-3
lr_rate = 0.05
clip = 5.0
batch_size = 64
decay = 0.75
decay_steps = 5000
